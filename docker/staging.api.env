NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/moozhayil?schema=public
REDIS_URL=redis://redis:6379
PUBLIC_BASE_URL=http://localhost:3080
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173,http://localhost:3080
TRUST_PROXY=false

JWT_SECRET=local_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=local_refresh_secret_at_least_32_chars
OTP_HASH_SECRET=local_otp_hash_secret_at_least_32_chars
PII_ENCRYPTION_SECRET=local_pii_encryption_secret_32_chars
ADMIN_JWT_SECRET=local_admin_jwt_secret_at_least_32_chars

SMS_PROVIDER_MODE=mock
PAYMENT_PROVIDER_MODE=mock
KYC_PROVIDER_MODE=mock
FIREBASE_MODE=mock

RAZORPAY_WEBHOOK_SECRET=mock_webhook_secret_for_local_dev
KYC_WEBHOOK_SECRET=mock_kyc_webhook_secret_32_chars_min
GOLD_RATE_WEBHOOK_SECRET=mock_gold_rate_webhook_secret_32_chars

STORAGE_BACKEND=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=ap-south-1
S3_BUCKET=moozhayil-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/moozhayil-media
S3_FORCE_PATH_STYLE=true

ENABLE_DEMO_SEEDS=false
WORKER_HEALTH_PORT=3001
LOG_LEVEL=info

# Moozhayil API — environment variables (Phase 1+)
# Copy to apps/api/.env for local development.
# Docker Compose staging uses docker/staging.api.env instead.

NODE_ENV=development
PORT=3080

# PostgreSQL 15 (Docker Compose uses port 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moozhayil?schema=public

# Redis (Docker Compose)
REDIS_URL=redis://localhost:6379

# Auth/session secrets — change before any shared/staging deploy.
JWT_SECRET=change_me_local_jwt_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_local_refresh_secret_at_least_32_chars
OTP_HASH_SECRET=change_me_local_otp_hash_secret_at_least_32_chars
PII_ENCRYPTION_SECRET=change_me_local_pii_encryption_secret_32_chars
ADMIN_JWT_SECRET=change_me_local_admin_jwt_secret_at_least_32_chars

# CORS (comma-separated origins for admin/mobile dev servers)
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5173,http://localhost:3080
TRUST_PROXY=false

# SMS OTP (mock logs OTP to console in development)
SMS_PROVIDER_MODE=mock
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

# KYC (mock uses OTP 654321 in development only)
KYC_PROVIDER_MODE=mock
KYC_PROVIDER_BASE_URL=
KYC_PROVIDER_API_KEY=
KYC_UPLOAD_DIR=./uploads/kyc
MEDIA_UPLOAD_DIR=./uploads/media

# Object storage — use local filesystem for bare-metal dev, s3 for Docker Compose
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

PUBLIC_BASE_URL=http://localhost:3080

# Payments (mock auto-captures in development)
PAYMENT_PROVIDER_MODE=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=mock_webhook_secret_for_local_dev

# Push notifications (mock on server in development)
FIREBASE_MODE=mock
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

KYC_WEBHOOK_SECRET=mock_kyc_webhook_secret_32_chars_min
GOLD_RATE_WEBHOOK_SECRET=mock_gold_rate_webhook_secret_32_chars

SENTRY_DSN=
ENABLE_DEMO_SEEDS=false
WORKER_HEALTH_PORT=3001
LOG_LEVEL=info

# Initial operator account (run: npm run seed:admin from apps/api)
ADMIN_SEED_EMAIL=admin@moozhayil.com
ADMIN_SEED_PASSWORD=change_me_before_running_seed_admin
ADMIN_SEED_NAME=Moozhayil Admin
ADMIN_SEED_ROLE=super_admin

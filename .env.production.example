# Moozhayil API — production environment template
# Copy values into your secret store (AWS Secrets Manager, etc.). Do NOT commit real secrets.

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/moozhayil?schema=public
REDIS_URL=rediss://USER:PASSWORD@HOST:6379

PUBLIC_BASE_URL=https://api.moozhayil.com
CORS_ALLOWED_ORIGINS=https://admin.moozhayil.com
TRUST_PROXY=true

JWT_SECRET=
JWT_REFRESH_SECRET=
OTP_HASH_SECRET=
PII_ENCRYPTION_SECRET=
ADMIN_JWT_SECRET=

SMS_PROVIDER_MODE=live
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

KYC_PROVIDER_MODE=live
KYC_PROVIDER_BASE_URL=
KYC_PROVIDER_API_KEY=
KYC_WEBHOOK_SECRET=

STORAGE_BACKEND=s3
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://cdn.moozhayil.com
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

PAYMENT_PROVIDER_MODE=live
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

FIREBASE_MODE=live
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

GOLD_RATE_WEBHOOK_SECRET=
SENTRY_DSN=
ENABLE_DEMO_SEEDS=false
WORKER_HEALTH_PORT=3001
LOG_LEVEL=info

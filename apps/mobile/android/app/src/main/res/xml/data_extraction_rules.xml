<?xml version="1.0" encoding="utf-8"?>
<!--
    Exclude sensitive app data from Android Auto Backup and Cloud Backup.
    flutter_secure_storage already uses EncryptedSharedPreferences — this
    ensures the raw keystore and Hive boxes are also excluded.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="file" path="hive"/>
        <exclude domain="file" path=".flutter_secure_storage"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="file" path="hive"/>
        <exclude domain="file" path=".flutter_secure_storage"/>
    </device-transfer>
</data-extraction-rules>

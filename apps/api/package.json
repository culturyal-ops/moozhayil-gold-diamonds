{
  "name": "@moozhayil/api",
  "version": "0.1.0",
  "private": true,
  "description": "Moozhayil Gold & Diamonds REST API",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "tsx src/jobs/worker.ts",
    "worker:start": "node dist/jobs/worker.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:deploy": "node dist/scripts/migrate.js",
    "start:prod": "node dist/scripts/migrate.js && node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:catalog": "tsx scripts/seed-catalog.ts",
    "seed:banner": "tsx scripts/seed-banner.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.896.0",
    "@prisma/client": "^6.19.0",
    "bullmq": "^5.79.1",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "prisma": "^6.19.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}

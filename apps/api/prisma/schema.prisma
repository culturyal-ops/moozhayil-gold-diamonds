generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  not_started
  in_progress
  in_review
  basic_verified
  enhanced_verified
  rejected

  @@map("kyc_status")
}

enum IntentType {
  wedding
  investment
  festival
  gift
  family
  other

  @@map("intent_type")
}

enum OtpSessionStatus {
  pending
  verified
  expired
  blocked

  @@map("otp_session_status")
}

enum DevicePlatform {
  ios
  android
  web

  @@map("device_platform")
}

enum AdminRole {
  super_admin
  catalog_manager
  kyc_reviewer
  order_manager
  finance_manager
  support_agent
  auditor

  @@map("admin_role")
}

enum LedgerAdjustmentStatus {
  pending
  approved
  rejected
  posted

  @@map("ledger_adjustment_status")
}

enum SarReviewStatus {
  pending
  approved
  rejected

  @@map("sar_review_status")
}

enum Purity {
  k14 @map("14k")
  k18 @map("18k")
  k22 @map("22k")
  k24 @map("24k")

  @@map("purity")
}

enum ProductImageType {
  white_background
  on_model
  detail
  lifestyle

  @@map("product_image_type")
}

enum GoalType {
  wedding
  investment
  festival
  gift
  family
  other

  @@map("goal_type")
}

enum SchemeType {
  aura
  crest
  dhanam
  gold_nidhi

  @@map("scheme_type")
}

enum GoalStatus {
  active
  contribution_due
  paused
  completed
  cancelled
  discontinued

  @@map("goal_status")
}

enum ContributionStatus {
  scheduled
  pending_payment
  processing
  completed
  payment_failed
  cancelled
  refunded

  @@map("contribution_status")
}

enum ContributionType {
  autopay
  manual
  bonus
  adjustment

  @@map("contribution_type")
}

enum LedgerEntryType {
  contribution_credit
  bonus_credit
  redemption_debit
  refund_credit
  manual_adjustment_credit
  manual_adjustment_debit

  @@map("ledger_entry_type")
}

enum LedgerStatus {
  pending
  posted
  reversed

  @@map("ledger_status")
}

enum PaymentMethodType {
  upi
  card
  netbanking

  @@map("payment_method_type")
}

enum PaymentProvider {
  razorpay

  @@map("payment_provider")
}

enum PaymentTransactionStatus {
  created
  pending
  authorized
  captured
  failed
  refund_initiated
  refunded
  reconciled

  @@map("payment_transaction_status")
}

enum PaymentTransactionType {
  goal_contribution
  order_payment
  refund
  mandate_setup

  @@map("payment_transaction_type")
}

enum OrderStatus {
  draft
  pending_payment
  confirmed
  processing
  shipped
  delivered
  delivery_failed
  cancelled
  refund_initiated
  refunded

  @@map("order_status")
}

enum OrderPaymentMethod {
  gold_balance
  upi
  card
  netbanking
  cod

  @@map("order_payment_method")
}

enum InventoryReservationStatus {
  reserved
  confirmed
  released
  expired

  @@map("inventory_reservation_status")
}

enum WebhookStatus {
  received
  processing
  processed
  ignored_duplicate
  failed

  @@map("webhook_status")
}

enum NotificationType {
  contribution_due
  contribution_success
  contribution_failed
  milestone_reached
  goal_completed
  order_confirmed
  order_shipped
  order_delivered
  kyc_verified
  kyc_rejected
  gold_rate_alert
  aura_suggestion
  product_back_in_stock
  refund_initiated
  refund_completed
  referral_reward

  @@map("notification_type")
}

enum AuraFlowType {
  goal_planning
  product_discovery
  gold_insights
  chat

  @@map("aura_flow_type")
}

enum AuraRole {
  aura
  user

  @@map("aura_role")
}

enum ReferralStatus {
  pending
  registered
  rewarded

  @@map("referral_status")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  phone         String    @unique @db.VarChar(15)
  name          String?   @db.VarChar(100)
  email         String?   @unique @db.VarChar(255)
  city          String?   @db.VarChar(100)
  kycStatus     KycStatus @default(not_started) @map("kyc_status")
  kycVerifiedAt DateTime? @map("kyc_verified_at") @db.Timestamptz(6)
  referralCode  String?   @unique @map("referral_code") @db.VarChar(20)
  memberSince   DateTime  @default(now()) @map("member_since") @db.Date
  lastActiveAt  DateTime? @map("last_active_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  authSessions    AuthSession[]
  devices         UserDevice[]
  intents         UserIntent[]
  otpSessions     OtpSession[]
  dreamVaultItems     DreamVaultItem[]
  cartItems           CartItem[]
  addresses           Address[]
  kycDocument         KycDocument?
  kycAadhaarSessions  KycAadhaarSession[]
  goals               Goal[]
  contributions       Contribution[]
  goldLedgerEntries   GoldLedgerEntry[]
  goldBalanceSnapshots GoldBalanceSnapshot[]
  userMilestones      UserMilestone[]
  paymentMethods      PaymentMethod[]
  paymentTransactions PaymentTransaction[]
  orders              Order[]
  inventoryReservations InventoryReservation[]
  notifications       Notification[]
  notificationPreference NotificationPreference?
  auraSessions        AuraSession[]
  productViews        ProductView[]
  referralsMade       Referral[] @relation("ReferrerReferrals")
  referralsReceived   Referral[] @relation("ReferredReferrals")
  ledgerAdjustments   LedgerAdjustment[]
  planInterests       PlanInterest[]

  @@index([kycStatus], map: "idx_users_kyc_status")
  @@index([lastActiveAt], map: "idx_users_last_active_at")
  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  deviceId         String?   @map("device_id") @db.Uuid
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_auth_sessions_user_id")
  @@index([deviceId], map: "idx_auth_sessions_device_id")
  @@index([expiresAt], map: "idx_auth_sessions_expires_at")
  @@map("auth_sessions")
}

model UserDevice {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @map("user_id") @db.Uuid
  platform          DevicePlatform
  pushToken         String         @unique @map("push_token") @db.VarChar(500)
  deviceFingerprint String?        @map("device_fingerprint") @db.VarChar(255)
  appVersion        String?        @map("app_version") @db.VarChar(50)
  lastSeenAt        DateTime?      @map("last_seen_at") @db.Timestamptz(6)
  disabledAt        DateTime?      @map("disabled_at") @db.Timestamptz(6)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions AuthSession[]

  @@index([userId], map: "idx_user_devices_user_id")
  @@index([lastSeenAt], map: "idx_user_devices_last_seen_at")
  @@map("user_devices")
}

model UserIntent {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  intentType IntentType @map("intent_type")
  selectedAt DateTime   @default(now()) @map("selected_at") @db.Timestamptz(6)
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_intents_user_id")
  @@index([intentType], map: "idx_user_intents_intent_type")
  @@map("user_intents")
}

model OtpSession {
  id         String           @id @default(uuid()) @db.Uuid
  phone      String           @db.VarChar(15)
  userId     String?          @map("user_id") @db.Uuid
  otpHash    String           @map("otp_hash") @db.VarChar(255)
  status     OtpSessionStatus @default(pending)
  attempts   Int              @default(0)
  expiresAt  DateTime         @map("expires_at") @db.Timestamptz(6)
  verifiedAt DateTime?        @map("verified_at") @db.Timestamptz(6)
  blockedAt  DateTime?        @map("blocked_at") @db.Timestamptz(6)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone], map: "idx_otp_sessions_phone")
  @@index([expiresAt], map: "idx_otp_sessions_expires_at")
  @@index([status], map: "idx_otp_sessions_status")
  @@map("otp_sessions")
}

model GoldRateHistory {
  id               String    @id @default(uuid()) @db.Uuid
  purity           Purity
  ratePerGramPaise Int       @map("rate_per_gram_paise")
  effectiveFrom    DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveTo      DateTime? @map("effective_to") @db.Timestamptz(6)
  source           String    @db.VarChar(100)
  createdByAdminId String?   @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([purity, effectiveFrom(sort: Desc)], map: "idx_gold_rate_history_purity_effective_from")
  @@index([purity, effectiveTo], map: "idx_gold_rate_history_purity_effective_to")
  @@map("gold_rate_history")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  parentId  String?  @map("parent_id") @db.Uuid
  iconUrl   String?  @map("icon_url") @db.VarChar(1000)
  imageUrl  String?  @map("image_url") @db.VarChar(1000)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId], map: "idx_categories_parent_id")
  @@index([isActive], map: "idx_categories_is_active")
  @@index([sortOrder], map: "idx_categories_sort_order")
  @@map("categories")
}

model Collection {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(255)
  description   String?
  coverImageUrl String?   @map("cover_image_url") @db.VarChar(1000)
  isActive      Boolean   @default(true) @map("is_active")
  isFeatured    Boolean   @default(false) @map("is_featured")
  validFrom     DateTime? @map("valid_from") @db.Date
  validTo       DateTime? @map("valid_to") @db.Date
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  products Product[]

  @@index([isActive], map: "idx_collections_is_active")
  @@index([isFeatured], map: "idx_collections_is_featured")
  @@index([validFrom], map: "idx_collections_valid_from")
  @@index([validTo], map: "idx_collections_valid_to")
  @@map("collections")
}

model Occasion {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  iconUrl    String?  @map("icon_url") @db.VarChar(1000)
  bgImageUrl String?  @map("bg_image_url") @db.VarChar(1000)
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  productTags ProductOccasionTag[]

  @@index([isActive], map: "idx_occasions_is_active")
  @@index([sortOrder], map: "idx_occasions_sort_order")
  @@map("occasions")
}

model Product {
  id              String    @id @default(uuid()) @db.Uuid
  sku             String    @unique @db.VarChar(50)
  name            String    @db.VarChar(255)
  description     String?
  categoryId      String    @map("category_id") @db.Uuid
  collectionId    String?   @map("collection_id") @db.Uuid
  purity          Purity
  hallmarkNumber  String?   @map("hallmark_number") @db.VarChar(50)
  weightGrams     Decimal   @map("weight_grams") @db.Decimal(10, 4)
  makingChargePct Decimal   @map("making_charge_pct") @db.Decimal(5, 2)
  wastagePct      Decimal   @default(0) @map("wastage_pct") @db.Decimal(5, 2)
  hasStones       Boolean   @default(false) @map("has_stones")
  stoneValuePaise Int       @default(0) @map("stone_value_paise")
  gstPct          Decimal   @default(3.00) @map("gst_pct") @db.Decimal(5, 2)
  stockQuantity   Int       @default(0) @map("stock_quantity")
  isPublished     Boolean   @default(false) @map("is_published")
  isFeatured      Boolean   @default(false) @map("is_featured")
  hasAr           Boolean   @default(false) @map("has_ar")
  arModelUrl      String?   @map("ar_model_url") @db.VarChar(1000)
  sortOrder       Int       @default(0) @map("sort_order")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  category        Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  collection      Collection?          @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  images          ProductImage[]
  occasionTags    ProductOccasionTag[]
  dreamVaultItems DreamVaultItem[]
  cartItems       CartItem[]
  goals           Goal[]
  orderItems      OrderItem[]
  inventoryReservations InventoryReservation[]
  productViews    ProductView[]

  @@index([sku], map: "idx_products_sku")
  @@index([categoryId], map: "idx_products_category_id")
  @@index([collectionId], map: "idx_products_collection_id")
  @@index([purity], map: "idx_products_purity")
  @@index([isFeatured], map: "idx_products_is_featured")
  @@index([isPublished, deletedAt], map: "idx_products_published_deleted_at")
  @@map("products")
}

model ProductImage {
  id        String           @id @default(uuid()) @db.Uuid
  productId String           @map("product_id") @db.Uuid
  s3Key     String           @map("s3_key") @db.VarChar(1000)
  cdnUrl    String           @map("cdn_url") @db.VarChar(1000)
  type      ProductImageType
  sortOrder Int              @default(0) @map("sort_order")
  isPrimary Boolean          @default(false) @map("is_primary")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_product_images_product_id")
  @@index([productId, sortOrder], map: "idx_product_images_product_id_sort_order")
  @@map("product_images")
}

model ProductOccasionTag {
  productId  String   @map("product_id") @db.Uuid
  occasionId String   @map("occasion_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  occasion Occasion @relation(fields: [occasionId], references: [id], onDelete: Cascade)

  @@id([productId, occasionId])
  @@index([occasionId], map: "idx_product_occasion_tags_occasion_id")
  @@index([productId], map: "idx_product_occasion_tags_product_id")
  @@map("product_occasion_tags")
}

model CmsBanner {
  id               String    @id @default(uuid()) @db.Uuid
  title            String    @db.VarChar(255)
  imageUrl         String    @map("image_url") @db.VarChar(1000)
  ctaLabel         String?   @map("cta_label") @db.VarChar(100)
  ctaRoute         String?   @map("cta_route") @db.VarChar(500)
  placement        String    @db.VarChar(50)
  sortOrder        Int       @default(0) @map("sort_order")
  validFrom        DateTime? @map("valid_from") @db.Timestamptz(6)
  validTo          DateTime? @map("valid_to") @db.Timestamptz(6)
  isActive         Boolean   @default(true) @map("is_active")
  createdByAdminId String?   @map("created_by_admin_id") @db.Uuid
  updatedByAdminId String?   @map("updated_by_admin_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([placement, isActive, sortOrder], map: "idx_cms_banners_placement_is_active_sort_order")
  @@index([validFrom], map: "idx_cms_banners_valid_from")
  @@index([validTo], map: "idx_cms_banners_valid_to")
  @@map("cms_banners")
}

model DreamVaultItem {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  productId String    @map("product_id") @db.Uuid
  goalId    String?   @map("goal_id") @db.Uuid
  addedAt   DateTime  @default(now()) @map("added_at") @db.Timestamptz(6)
  removedAt DateTime? @map("removed_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  goal    Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_dream_vault_items_user_id")
  @@index([productId], map: "idx_dream_vault_items_product_id")
  @@index([goalId], map: "idx_dream_vault_items_goal_id")
  @@map("dream_vault_items")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId], map: "cart_items_user_id_product_id_key")
  @@index([userId], map: "idx_cart_items_user_id")
  @@index([productId], map: "idx_cart_items_product_id")
  @@map("cart_items")
}

model Address {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  label     String?   @db.VarChar(50)
  fullName  String    @map("full_name") @db.VarChar(100)
  phone     String    @db.VarChar(15)
  line1     String    @db.VarChar(255)
  line2     String?   @db.VarChar(255)
  city      String    @db.VarChar(100)
  state     String    @db.VarChar(100)
  pincode   String    @db.VarChar(6)
  isDefault Boolean   @default(false) @map("is_default")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId], map: "idx_addresses_user_id")
  @@index([pincode], map: "idx_addresses_pincode")
  @@index([userId, isDefault], map: "idx_addresses_user_id_is_default")
  @@map("addresses")
}

model ServiceablePincode {
  id                    String   @id @default(uuid()) @db.Uuid
  pincode               String   @unique @db.VarChar(6)
  city                  String   @db.VarChar(100)
  state                 String   @db.VarChar(100)
  serviceable           Boolean
  estimatedDeliveryDays Int?     @map("estimated_delivery_days")
  pickupAvailable       Boolean  @default(true) @map("pickup_available")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([serviceable], map: "idx_serviceable_pincodes_serviceable")
  @@map("serviceable_pincodes")
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  name         String    @db.VarChar(100)
  role         AdminRole
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  disabledAt   DateTime? @map("disabled_at") @db.Timestamptz(6)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  reviewedKycDocuments      KycDocument[]      @relation("KycReviewer")
  requestedLedgerAdjustments LedgerAdjustment[] @relation("LedgerAdjustmentRequester")
  approvedLedgerAdjustments  LedgerAdjustment[] @relation("LedgerAdjustmentApprover")
  decidedSarReviews          SarReview[]        @relation("SarReviewDecider")

  @@index([email], map: "idx_admin_users_email")
  @@index([role], map: "idx_admin_users_role")
  @@map("admin_users")
}

model KycDocument {
  id                      String    @id @default(uuid()) @db.Uuid
  userId                  String    @unique @map("user_id") @db.Uuid

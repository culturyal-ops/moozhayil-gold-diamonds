  readAt          DateTime?        @map("read_at") @db.Timestamptz(6)
  scheduledFor    DateTime?        @map("scheduled_for") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_notifications_user_id_created_at")
  @@index([userId, isRead], map: "idx_notifications_user_id_is_read")
  @@index([scheduledFor], map: "idx_notifications_scheduled_for")
  @@map("notifications")
}

model NotificationPreference {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  pushEnabled           Boolean  @default(true) @map("push_enabled")
  contributionsEnabled  Boolean  @default(true) @map("contributions_enabled")
  milestonesEnabled     Boolean  @default(true) @map("milestones_enabled")
  ordersEnabled         Boolean  @default(true) @map("orders_enabled")
  kycEnabled            Boolean  @default(true) @map("kyc_enabled")
  auraEnabled           Boolean  @default(true) @map("aura_enabled")
  goldRateAlertEnabled  Boolean  @default(false) @map("gold_rate_alert_enabled")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model AuraSession {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  flowType              AuraFlowType @map("flow_type")
  summary               String?
  startedAt             DateTime     @map("started_at") @db.Timestamptz(6)
  endedAt               DateTime?    @map("ended_at") @db.Timestamptz(6)
  expiresAt             DateTime     @map("expires_at") @db.Timestamptz(6)
  goalCreated           Boolean      @default(false) @map("goal_created")
  productsAddedToVault  Int          @default(0) @map("products_added_to_vault")
  goalIdCreated         String?      @map("goal_id_created") @db.Uuid
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal     Goal?         @relation(fields: [goalIdCreated], references: [id], onDelete: SetNull)
  messages AuraMessage[]

  @@index([userId, startedAt(sort: Desc)], map: "idx_aura_sessions_user_id_started_at")
  @@index([expiresAt], map: "idx_aura_sessions_expires_at")
  @@map("aura_sessions")
}

model AuraMessage {
  id        String    @id @default(uuid()) @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  role      AuraRole
  content   String
  metadata  Json?
  sequence  Int
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  session AuraSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence], map: "aura_messages_session_id_sequence_key")
  @@index([sessionId, sequence], map: "idx_aura_messages_session_id_sequence")
  @@map("aura_messages")
}

model ProductView {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  anonymousId String?  @map("anonymous_id") @db.VarChar(100)
  productId   String   @map("product_id") @db.Uuid
  source      String?  @db.VarChar(50)
  viewedAt    DateTime @map("viewed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt(sort: Desc)], map: "idx_product_views_user_id_viewed_at")
  @@index([productId, viewedAt(sort: Desc)], map: "idx_product_views_product_id_viewed_at")
  @@index([anonymousId], map: "idx_product_views_anonymous_id")
  @@map("product_views")
}

model Referral {
  id              String         @id @default(uuid()) @db.Uuid
  referrerUserId  String         @map("referrer_user_id") @db.Uuid
  referredUserId  String?        @unique @map("referred_user_id") @db.Uuid
  referralCode    String         @map("referral_code") @db.VarChar(20)
  status          ReferralStatus @default(pending)
  registeredAt    DateTime?      @map("registered_at") @db.Timestamptz(6)
  rewardedAt      DateTime?      @map("rewarded_at") @db.Timestamptz(6)
  rewardType      String?        @map("reward_type") @db.VarChar(50)
  rewardValuePaise Int?          @map("reward_value_paise")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  referrer User  @relation("ReferrerReferrals", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred User? @relation("ReferredReferrals", fields: [referredUserId], references: [id], onDelete: SetNull)

  @@index([referrerUserId], map: "idx_referrals_referrer_user_id")
  @@index([status], map: "idx_referrals_status")
  @@index([referralCode], map: "idx_referrals_referral_code")
  @@map("referrals")
}

model StoreLocation {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  address       String
  city          String   @db.VarChar(100)
  state         String   @db.VarChar(100)
  pincode       String   @db.VarChar(6)
  phone         String   @db.VarChar(15)
  latitude      Decimal  @db.Decimal(9, 6)
  longitude     Decimal  @db.Decimal(9, 6)
  openingHours  Json     @map("opening_hours")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([city], map: "idx_store_locations_city")
  @@index([pincode], map: "idx_store_locations_pincode")
  @@index([isActive], map: "idx_store_locations_is_active")
  @@index([latitude, longitude], map: "idx_store_locations_lat_lng")
  @@map("store_locations")
}
